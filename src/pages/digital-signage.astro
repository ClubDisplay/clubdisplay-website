---
import BaseLayout from "../layouts/BaseLayout.astro";
import TrustBar from "../components/TrustBar.astro";
import Solutions from "../components/Solutions.astro";
import WhyDigitalSignage from "../components/WhyDigitalSignage.astro";
import Workflow from "../components/Workflow.astro";
import CasesPreview from "../components/CasesPreview.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
---

<BaseLayout
  title="Digital Signage Oplossingen & Advies | ClubDisplay"
  description="ClubDisplay is hét digital signage bureau voor narrowcasting, hospitality TV, IPTV, LG Pro:Centric, digitale menuborden en coffeeshop signage. Advies, installatie en beheer uit één hand."
  canonical="https://clubdisplay.nl/digital-signage/"
  currentPath="/digital-signage/"
>
  <section class="ds-hero">
    <div class="container">
      <div class="ds-hero-inner">
        <span class="hero-badge">Digital signage specialist</span>
        <h1 class="ds-hero-title">Digital signage oplossingen voor elk bedrijf</h1>
        <p class="ds-hero-text">
          ClubDisplay helpt organisaties met het inzetten van digitale schermen voor communicatie, informatie en entertainment. Of je nu een hotel, restaurant, coffeeshop, winkel of kantoor runt — wij leveren de juiste oplossing, compleet met advies, hardware, software, installatie en beheer.
        </p>
        <div class="hero-actions">
          <a href="/plan-jouw-gesprek/" class="btn btn-lg">Plan een adviesgesprek</a>
          <a href="#oplossingen" class="btn btn-lg btn-outline">Bekijk alle oplossingen</a>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  <Solutions />

  <section class="ds-werkt">
    <div class="container">
      <div class="section-label">Hoe het werkt</div>
      <h2 class="section-title">Zo werkt digital signage</h2>
      <div class="ds-werkt-grid">
        <div class="ds-werkt-card">
          <div class="ds-werkt-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/></svg>
          </div>
          <h3>1. Scherm</h3>
          <p>Een professioneel display van LG of Samsung, geschikt voor 24/7 gebruik en afgestemd op jouw locatie.</p>
        </div>
        <div class="ds-werkt-card">
          <div class="ds-werkt-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 8 14 13 12 20 8 22 10 14 5 11 13 9 9 3 17 7 20 2 18 8 23 11 19 12 16 16 14 18 15 10"/></svg>
          </div>
          <h3>2. Software</h3>
          <p>Ons cloudplatform maakt het eenvoudig om content te beheren, afspeellijsten in te stellen en schermen te monitoren.</p>
        </div>
        <div class="ds-werkt-card">
          <div class="ds-werkt-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3>3. Content</h3>
          <p>Wij verzorgen professionele content in jouw huisstijl: van menuborden en promoties tot informatieve schermen.</p>
        </div>
      </div>
      <p class="ds-werkt-voordeel">Alles uit één hand: wij adviseren, leveren, installeren en blijven ondersteunen.</p>
    </div>
  </section>

  <WhyDigitalSignage />

  <section class="ds-voor-wie">
    <div class="container">
      <div class="section-label">Voor wie</div>
      <h2 class="section-title">Voor elke sector de juiste aanpak</h2>
      <div class="ds-sectoren">
        <a href="/zakelijke-iptv-voor-hotels-en-bedrijven/" class="ds-sector-card">
          <div class="ds-sector-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3>Hotels & hospitality</h3>
          <p>Hospitality TV, IPTV, LG Pro:Centric en Chromecast voor een onvergetelijk gastverblijf.</p>
        </a>
        <a href="/digitale-menuborden/" class="ds-sector-card">
          <div class="ds-sector-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h12"/></svg>
          </div>
          <h3>Horeca & restaurants</h3>
          <p>Digitale menuborden met kassakoppeling, dagdelen en real-time prijswijzigingen.</p>
        </a>
        <a href="/coffeeshop-signage/" class="ds-sector-card">
          <div class="ds-sector-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="M12 18v4"/></svg>
          </div>
          <h3>Coffeeshops</h3>
          <p>Digitale prijslijsten, productinformatie en wachtrijcommunicatie — professioneel en compliant.</p>
        </a>
        <a href="/retail/" class="ds-sector-card">
          <div class="ds-sector-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          </div>
          <h3>Retail</h3>
          <p>Etalageschermen, productinformatie en promoties die klanten direct aanspreken.</p>
        </a>
        <a href="/narrowcasting-interne-communicatie/" class="ds-sector-card">
          <div class="ds-sector-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Kantoor & interne communicatie</h3>
          <p>Narrowcasting voor medewerkerscommunicatie, roosters en bedrijfsinformatie.</p>
        </a>
        <a href="/wayfinding-en-room-signage/" class="ds-sector-card">
          <div class="ds-sector-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 6.9 8 11.7z"/></svg>
          </div>
          <h3>Zorg & welzijn</h3>
          <p>Informatieschermen, wayfinding en wachtverzachting voor zorginstellingen.</p>
        </a>
      </div>
    </div>
  </section>

  <Workflow />

  <CasesPreview />

  <FAQ />

  <CTA />

</BaseLayout>

<style>
  .ds-hero {
    padding: 5rem 0 4rem;
    background: linear-gradient(180deg, var(--bg) 0%, var(--primary-50) 100%);
  }
  .ds-hero-inner { max-width: 720px; }
  .hero-badge {
    display: inline-block;
    background: var(--primary);
    color: #fff;
    padding: 0.375rem 1rem;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    letter-spacing: 0.01em;
  }
  .ds-hero-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .ds-hero-text {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 2.25rem;
    max-width: 600px;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .ds-werkt { padding: 6rem 0; background: var(--bg); }
  .section-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    line-height: 1.15;
  }
  .ds-werkt-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }
  .ds-werkt-card {
    padding: 2rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border);
    text-align: center;
  }
  .ds-werkt-icon {
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--primary-50);
    border-radius: var(--radius-lg);
    color: var(--primary);
    margin: 0 auto 1.25rem;
  }
  .ds-werkt-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .ds-werkt-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.6;
  }
  .ds-werkt-voordeel {
    text-align: center;
    font-size: 0.938rem;
    color: var(--text-secondary);
    margin-top: 2.5rem;
    font-weight: 500;
  }

  .ds-voor-wie { padding: 6rem 0; background: var(--bg-alt); }
  .ds-sectoren {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .ds-sector-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border);
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .ds-sector-card:hover {
    border-color: var(--primary-light);
    box-shadow: 0 8px 32px rgba(30,64,175,0.08);
    transform: translateY(-2px);
    color: inherit;
  }
  .ds-sector-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--primary-50);
    border-radius: var(--radius);
    color: var(--primary);
    margin-bottom: 1rem;
  }
  .ds-sector-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    margin: 0 0 0.375rem;
  }
  .ds-sector-card p {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .ds-hero { padding: 3rem 0 2.5rem; }
    .ds-hero-title { font-size: 2rem; }
    .ds-werkt { padding: 3.5rem 0; }
    .ds-werkt-grid { grid-template-columns: 1fr; gap: 1rem; }
    .ds-voor-wie { padding: 3.5rem 0; }
    .ds-sectoren { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .ds-hero-title { font-size: 1.75rem; }
    .ds-sectoren { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
  }
</style>
