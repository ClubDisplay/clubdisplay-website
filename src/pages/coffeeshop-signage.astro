---
import BaseLayout from "../layouts/BaseLayout.astro";

const iconPaths = {
  menu: "M4 5h16 M4 12h16 M4 19h12",
  pos: "M5 3h14v18H5z M8 7h8 M8 11h8 M8 15h3 M15 18h1",
  api: "M8 9l-4 3 4 3 M16 9l4 3-4 3 M13 6l-2 12",
  touch: "M7 3h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z M12 17v.1 M9 9l3-3 3 3 M12 6v8",
  shield: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  refresh: "M20 6v5h-5 M4 18v-5h5 M18.3 9A7 7 0 0 0 6.4 6.7L4 9 M5.7 15a7 7 0 0 0 11.9 2.3L20 15",
  display: "M3 5h18v11H3z M8 21h8 M12 16v5",
  info: "M12 17v-5 M12 8h.1 M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z",
  design: "M4 20c2.8.2 5-.5 6.5-2 1.1-1.1 1.1-2.9 0-4s-2.9-1.1-4 0C5 15.5 4.3 17.2 4 20z M11 13l7.5-7.5a2.1 2.1 0 0 1 3 3L14 16",
  network: "M6 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M18 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M12 22a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M8.4 7.1l2.1 9.2 M15.6 7.1l-2.1 9.2 M9 19h6",
  queue: "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z M23 8h-6 M20 5v6",
  hardware: "M4 6h16v10H4z M8 20h8 M12 16v4 M7 9h5 M7 12h7",
  support: "M12 2a8 8 0 0 0-8 8v3a3 3 0 0 0 3 3h1v-6H6a6 6 0 0 1 12 0h-2v6h1a3 3 0 0 0 3-3v-3a8 8 0 0 0-8-8z M9 19h6",
} as const;

const heroSlides = [
  { src: "/images/digitale-menuborden/piramide-baliescherm.jpg", alt: "Baliescherm met digitale prijslijst bij een coffeeshop" },
  { src: "/images/digitale-menuborden/grasscompany.jpg", alt: "Digitale prijslijsten bij The Grass Company" },
  { src: "/images/digitale-menuborden/cs-roots.jpg", alt: "Digitale menuborden en signage bij Coffeeshop Roots" },
  { src: "/images/cases/piramide01.jpg", alt: "Coffeeshop signage scherm bij Cannabiswinkel Piramide" },
  { src: "/images/coffeeshop/infotouch_Riskey.jpg", alt: "Info touch display bij Coffeeshop Risky Business" },
  { src: "/images/coffeeshop/infotouch_Africa.jpg", alt: "Info touch display bij Coffeeshop Africa" },
  { src: "/images/coffeeshop/huyskamer_Menubord.jpg", alt: "Digitaal menubord bij Coffeeshop de Huyskamer" },
] as const;

const proofHighlights = [
  { title: "Digitale prijslijsten", text: "Duidelijk, actueel en in eigen huisstijl", icon: "menu", tone: "blue" },
  { title: "POS-koppeling", text: "Prijzen automatisch vanuit kassa/API", icon: "pos", tone: "teal" },
  { title: "Touch informatie", text: "Productinformatie zonder extra baliedruk", icon: "touch", tone: "amber" },
  { title: "Installatie & beheer", text: "Schermen, software, content en support", icon: "shield", tone: "violet" },
] as const;

const solutionCards = [
  {
    title: "Digitale menuborden en prijslijsten",
    text: "Toon categorieen, producten, prijzen, aanbiedingen en huisregels overzichtelijk op schermen boven of achter de balie.",
    icon: "menu",
    tone: "blue",
  },
  {
    title: "Automatische kassakoppeling",
    text: "Wanneer uw kassasysteem JSON, API of een bruikbare export beschikbaar maakt, kunnen wijzigingen direct door naar het scherm.",
    icon: "api",
    tone: "teal",
  },
  {
    title: "Balieschermen en vandalismebestendige displays",
    text: "Voor balies, counters en drukke omgevingen leveren we robuuste schermen die professioneel worden ingebouwd of gemonteerd.",
    icon: "display",
    tone: "amber",
  },
  {
    title: "Informatieve touch displays",
    text: "Laat bezoekers zelf productinformatie, eigenschappen, categorieen of toelichting bekijken via een helder touch-menu.",
    icon: "touch",
    tone: "violet",
  },
  {
    title: "Promotie en wachtrijcommunicatie",
    text: "Gebruik extra schermen voor acties, openingstijden, veiligheidsinformatie, routing of content die de wachtrij rustiger maakt.",
    icon: "queue",
    tone: "blue",
  },
  {
    title: "Content in huisstijl",
    text: "Wij ontwerpen templates die passen bij uw shop, zodat menu, iconen, regels en productinformatie professioneel ogen.",
    icon: "design",
    tone: "teal",
  },
] as const;

const posSteps = [
  { title: "1. Data uit de kassa", text: "We bekijken welke JSON, API, export of datakoppeling uw POS-systeem beschikbaar stelt." },
  { title: "2. Mapping naar schermcontent", text: "Productnamen, categorieen, prijzen, beschikbaarheid en eventuele labels worden gekoppeld aan het menubordtemplate." },
  { title: "3. Automatisch publiceren", text: "Een wijziging in de kassa kan daarna automatisch zichtbaar worden op de juiste schermen of zones." },
] as const;

const cases = [
  {
    title: "Cannabiswinkel Piramide Bussum",
    text: "65-inch signage display plus drie 32-inch vandalismebestendige balieschermen, gekoppeld aan het kassasysteem.",
    href: "/project/cannabiswinkel-piramide-bussum/",
    image: "/images/digitale-menuborden/piramide-baliescherm.jpg",
  },
  {
    title: "The Grass Company Tilburg",
    text: "Drie 65-inch LG Digital Signage Pro-schermen met anti-glare coating en gebruiksvriendelijke digitale prijslijsten.",
    href: "/project/digitale-prijslijsten-voor-the-grass-company-tilburg/",
    image: "/images/digitale-menuborden/grasscompany.jpg",
  },
  {
    title: "Coffeeshop Roots Amersfoort",
    text: "Digitale menuborden en extra signage-schermen voor menu, aanbiedingen en informatie in de shop.",
    href: "/project/digitale-menuborden-en-signage-voor-coffeeshop-roots-amersfoort/",
    image: "/images/digitale-menuborden/cs-roots.jpg",
  },
  {
    title: "Touch infopanel Kronkel Nijmegen",
    text: "Informatief touch display waarmee bezoekers productinformatie zelfstandig kunnen bekijken.",
    href: "/project/touch-infopanel-coffeeshop-kronkel-nijmegen/",
    image: "/images/kronkel_infopanel-400x284.jpg",
  },
] as const;

const deliveryCards = [
  { title: "Advies en schermplan", text: "We bepalen welke schermen passen bij balie, wand, wachtruimte, lichtinval en kijkafstand.", icon: "hardware", tone: "blue" },
  { title: "Software en koppelingen", text: "Onze signage software stuurt de schermen aan en kan worden gekoppeld aan POS-data wanneer die beschikbaar is.", icon: "network", tone: "teal" },
  { title: "Installatie op locatie", text: "Montage, bekabeling, netwerk, player-inrichting en schermconfiguratie worden compleet verzorgd.", icon: "display", tone: "amber" },
  { title: "Beheer en support", text: "Na oplevering helpen we met wijzigingen, monitoring, content, templates en doorontwikkeling.", icon: "support", tone: "violet" },
] as const;
---

<BaseLayout
  title="Coffeeshop Signage | Digitale prijslijsten, menuborden en POS-koppelingen"
  description="Coffeeshop signage voor digitale menuborden, prijslijsten, balieschermen, touch displays en POS-koppelingen. ClubDisplay verzorgt advies, content, installatie en beheer."
  canonical="https://clubdisplay.nl/coffeeshop-signage/"
  currentPath="/coffeeshop-signage/"
>
  <section class="commercial-hero coffeeshop-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Coffeeshop signage</span>
        <h1>Digitale prijslijsten voor coffeeshops</h1>
        <p>
          Toon producten, prijzen en informatie professioneel op menuborden, balieschermen en touch displays. Met een POS-koppeling via JSON/API kunnen wijzigingen uit uw kassa automatisch zichtbaar worden op het scherm.
        </p>
        <div class="hero-actions">
          <a href="/plan-jouw-gesprek/" class="btn btn-lg">Plan een adviesgesprek</a>
          <a href="#pos-koppeling" class="btn btn-lg btn-outline">Bekijk kassakoppeling</a>
        </div>
      </div>
      <div class="hero-media coffeeshop-slider" data-coffeeshop-slider>
        <div class="coffeeshop-slider-track">
          {heroSlides.map((slide, index) => (
            <img
              src={slide.src}
              alt={slide.alt}
              class:list={["coffeeshop-slide", { active: index === 0 }]}
              loading={index === 0 ? "eager" : "lazy"}
              decoding="async"
            />
          ))}
        </div>
        <div class="coffeeshop-slider-dots" aria-label="Coffeeshop signage voorbeelden">
          {heroSlides.map((_, index) => (
            <button
              type="button"
              class:list={["coffeeshop-slider-dot", { active: index === 0 }]}
              aria-label={`Toon voorbeeld ${index + 1}`}
              data-coffeeshop-dot={index}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="proof-strip">
    <div class="container proof-grid">
      {proofHighlights.map((item) => (
        <article class:list={["proof-card", `tone-${item.tone}`]}>
          <span class="card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path d={iconPaths[item.icon]} />
            </svg>
          </span>
          <div>
            <strong>{item.title}</strong>
            <span>{item.text}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="commercial-section">
    <div class="container split-grid">
      <div>
        <span class="eyebrow">Voor coffeeshops</span>
        <h2>Van prijslijst tot interactieve productinformatie</h2>
        <p>
          Coffeeshops zoeken steeds vaker een professionele manier om producten, prijzen en informatie helder te tonen. Papieren lijsten, losse monitoren of USB-oplossingen zijn lastig bij te houden en ogen snel verouderd. Digitale signage maakt uw aanbod rustiger, duidelijker en eenvoudiger te beheren.
        </p>
        <p>
          Wij combineren schermen, software, content en koppelingen. Daardoor kunt u beginnen met een eenvoudige digitale prijslijst, maar ook doorgroeien naar automatische POS-koppelingen, touch-informatiepunten en meerdere schermzones per locatie.
        </p>
      </div>
      <div class="feature-list">
        {solutionCards.slice(0, 4).map((item) => (
          <article class:list={["feature-card", `tone-${item.tone}`]}>
            <span class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d={iconPaths[item.icon]} />
              </svg>
            </span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="commercial-section section-alt" id="pos-koppeling">
    <div class="container pos-grid">
      <div class="pos-copy">
        <span class="eyebrow">POS / kassakoppeling</span>
        <h2>Wijziging in de kassa? Dan kan het menubord automatisch mee</h2>
        <p>
          Vrijwel iedere coffeeshop werkt met een kassasysteem. Als dat systeem productdata beschikbaar stelt via JSON, API, export of een andere bruikbare koppeling, kunnen wij de digitale prijslijst automatiseren. Producten, categorieen, prijzen en beschikbaarheid worden dan vanuit de bron gevuld.
        </p>
        <p>
          Dat voorkomt dubbel werk, verkleint de kans op prijsverschillen tussen balie en scherm en zorgt dat medewerkers niet op meerdere plekken dezelfde wijziging hoeven door te voeren.
        </p>
        <div class="section-actions">
          <a href="/contact/" class="btn btn-lg">Bespreek uw kassasysteem</a>
        </div>
      </div>
      <div class="pos-steps">
        {posSteps.map((item) => (
          <article>
            <strong>{item.title}</strong>
            <span>{item.text}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="commercial-section">
    <div class="container cards-section">
      <div class="section-head">
        <span class="eyebrow">Schermoplossingen</span>
        <h2>Schermen op de plekken waar uw bezoekers beslissen</h2>
        <p>
          Een coffeeshop heeft vaak meerdere communicatiemomenten: buiten of bij entree, in de wachtrij, aan de balie en bij productkeuze. Daar stemmen we de schermen, content en bediening op af.
        </p>
      </div>
      <div class="cards-grid">
        {solutionCards.map((item) => (
          <article class:list={["application-card", `tone-${item.tone}`]}>
            <span class="application-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d={iconPaths[item.icon]} />
              </svg>
            </span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="commercial-section dark-band">
    <div class="container dark-grid">
      <div>
        <span class="eyebrow">Balie en touch</span>
        <h2>Laat bezoekers informatie bekijken zonder extra druk op de balie</h2>
        <p>
          Informatieve touch displays zijn geschikt voor productuitleg, categorieen, eigenschappen, huisregels en meertalige iconen. Bezoekers kunnen zelfstandig informatie bekijken, terwijl medewerkers zich kunnen richten op service en verkoop.
        </p>
        <ul class="check-list check-list-light">
          <li>Productinformatie overzichtelijk en visueel presenteren.</li>
          <li>Iconen en korte teksten voor internationaal publiek.</li>
          <li>Geschikt voor balie, wand, zuil of informatief display.</li>
          <li>Te combineren met digitale prijslijsten en promotieschermen.</li>
        </ul>
      </div>
      <figure class="video-card">
        <iframe
          src="https://www.youtube.com/embed/jDr1B7mgrYQ"
          title="Info touch display voor coffeeshop productinformatie"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </figure>
    </div>
  </section>

  <section class="commercial-section section-alt">
    <div class="container cards-section">
      <div class="section-head">
        <span class="eyebrow">Projecten</span>
        <h2>Voorbeelden uit coffeeshops</h2>
        <p>
          Uit onze bestaande projecten blijkt hoe breed coffeeshop signage kan zijn: van automatische balieprijslijsten tot grote menuschermen en touch-informatiepunten.
        </p>
      </div>
      <div class="case-grid">
        {cases.map((item) => (
          <a href={item.href} class="case-card">
            <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
            <div>
              <strong>{item.title}</strong>
              <span>{item.text}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="commercial-section">
    <div class="container split-grid">
      <div>
        <span class="eyebrow">Aanpak</span>
        <h2>Compleet geregeld: schermen, software, content, koppeling en support</h2>
        <p>
          ClubDisplay levert geen losse monitor, maar een werkende oplossing. We kijken naar schermpositie, licht, montage, bekabeling, netwerk, POS-data, contentstructuur en beheer. Daarna richten we alles zo in dat uw team er praktisch mee kan werken.
        </p>
      </div>
      <div class="feature-list">
        {deliveryCards.map((item) => (
          <article class:list={["feature-card", `tone-${item.tone}`]}>
            <span class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d={iconPaths[item.icon]} />
              </svg>
            </span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="commercial-cta">
    <div class="container cta-inner">
      <span class="eyebrow">Advies voor uw shop</span>
      <h2>Wilt u uw prijslijsten, balieschermen of touch displays professionaliseren?</h2>
      <p>
        We denken mee over de juiste schermopstelling, huisstijl, productstructuur en eventuele kassakoppeling. Zo krijgt u een oplossing die rust brengt aan de balie en dagelijks makkelijk te beheren is.
      </p>
      <div class="hero-actions">
        <a href="/plan-jouw-gesprek/" class="btn btn-lg">Plan een adviesgesprek</a>
        <a href="/cases/" class="btn btn-lg btn-outline">Bekijk projecten</a>
      </div>
    </div>
  </section>

  <script>
    const slider = document.querySelector("[data-coffeeshop-slider]");
    const slides = Array.from(slider?.querySelectorAll(".coffeeshop-slide") ?? []);
    const dots = Array.from(slider?.querySelectorAll(".coffeeshop-slider-dot") ?? []);
    let activeSlide = 0;
    let sliderTimer;

    const showSlide = (index) => {
      if (!slides.length) return;
      activeSlide = (index + slides.length) % slides.length;
      slides.forEach((slide, slideIndex) => slide.classList.toggle("active", slideIndex === activeSlide));
      dots.forEach((dot, dotIndex) => dot.classList.toggle("active", dotIndex === activeSlide));
    };

    const startSlider = () => {
      if (slides.length <= 1) return;
      sliderTimer = window.setInterval(() => showSlide(activeSlide + 1), 4600);
    };

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        if (sliderTimer) window.clearInterval(sliderTimer);
        showSlide(index);
        startSlider();
      });
    });

    startSlider();
  </script>

  <style>
    .commercial-hero {
      padding: 5.5rem 0 4.5rem;
      background: linear-gradient(135deg, #ffffff 0%, #eef6ff 100%);
      overflow: hidden;
    }

    .hero-grid,
    .split-grid,
    .pos-grid,
    .dark-grid {
      align-items: center;
      display: grid;
      gap: 4rem;
      grid-template-columns: minmax(0, 0.95fr) minmax(360px, 1.05fr);
    }

    .hero-copy h1,
    .commercial-section h2,
    .commercial-cta h2 {
      color: #0f172a;
      letter-spacing: 0;
      line-height: 1.05;
    }

    .hero-copy h1 {
      font-size: clamp(2.35rem, 4.8vw, 4.65rem);
      margin: 0 0 1.25rem;
    }

    .hero-copy p,
    .commercial-section p,
    .commercial-cta p {
      color: #475569;
      font-size: 1.08rem;
      line-height: 1.75;
    }

    .hero-copy p {
      max-width: 660px;
    }

    .coffeeshop-hero {
      padding: 4.5rem 0 4rem;
    }

    .coffeeshop-hero .hero-grid {
      grid-template-columns: minmax(420px, 0.82fr) minmax(460px, 1.18fr);
      gap: 3.25rem;
    }

    .coffeeshop-hero .hero-copy h1 {
      font-size: clamp(2.7rem, 4vw, 4.15rem);
      max-width: 680px;
    }

    .coffeeshop-hero .hero-copy p {
      max-width: 620px;
    }

    .coffeeshop-hero .hero-media {
      min-height: 390px;
    }

    .coffeeshop-hero .hero-media img {
      min-height: 390px;
    }

    .eyebrow {
      color: var(--primary);
      display: inline-block;
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      margin-bottom: 1rem;
      text-transform: uppercase;
    }

    .hero-actions,
    .section-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 2rem;
    }

    .hero-media,
    .image-card {
      background: #0f172a;
      border-radius: 22px;
      box-shadow: 0 28px 70px rgba(15, 23, 42, 0.18);
      margin: 0;
      min-height: 430px;
      overflow: hidden;
      position: relative;
    }

    .hero-media img,
    .image-card img {
      border-radius: 0;
      height: 100%;
      min-height: 430px;
      object-fit: cover;
      width: 100%;
    }

    .video-card {
      aspect-ratio: 16 / 9;
      background: #020617;
      border-radius: 22px;
      box-shadow: 0 28px 70px rgba(0, 0, 0, 0.28);
      margin: 0;
      overflow: hidden;
      position: relative;
      width: 100%;
    }

    .video-card iframe {
      border: 0;
      height: 100%;
      inset: 0;
      position: absolute;
      width: 100%;
    }

    .coffeeshop-slider-track {
      height: 100%;
      inset: 0;
      position: absolute;
      width: 100%;
    }

    .coffeeshop-slide {
      inset: 0;
      opacity: 0;
      position: absolute;
      transform: scale(1.03);
      transition: opacity 900ms ease, transform 4200ms ease;
    }

    .coffeeshop-slide.active {
      opacity: 1;
      transform: scale(1);
      z-index: 1;
    }

    .coffeeshop-slider-dots {
      align-items: center;
      bottom: 1.15rem;
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      left: 0;
      position: absolute;
      right: 0;
      z-index: 2;
    }

    .coffeeshop-slider-dot {
      background: rgba(255, 255, 255, 0.62);
      border: 0;
      border-radius: 999px;
      cursor: pointer;
      height: 9px;
      padding: 0;
      transition: background 180ms ease, width 180ms ease;
      width: 9px;
    }

    .coffeeshop-slider-dot.active {
      background: #ffffff;
      width: 28px;
    }

    .proof-strip {
      background: #ffffff;
      border-bottom: 1px solid #e2e8f0;
      border-top: 1px solid #e2e8f0;
      padding: 1.2rem 0;
    }

    .proof-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .proof-card,
    .feature-card,
    .application-card,
    .case-card {
      background: #ffffff;
      border: 1px solid #dbe5f2;
      border-radius: 16px;
      transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    }

    .proof-card {
      align-items: center;
      display: flex;
      gap: 0.9rem;
      padding: 1rem;
    }

    .proof-card strong,
    .proof-card span {
      display: block;
    }

    .proof-card strong {
      color: #0f172a;
      font-size: 0.98rem;
      margin-bottom: 0.2rem;
    }

    .proof-card div span,
    .case-card span {
      color: #64748b;
      line-height: 1.55;
    }

    .card-icon,
    .feature-icon,
    .application-icon {
      align-items: center;
      border-radius: 14px;
      display: inline-flex;
      flex: 0 0 auto;
      height: 44px;
      justify-content: center;
