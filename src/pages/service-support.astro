---
import BaseLayout from "../layouts/BaseLayout.astro";

const iconPaths = {
  headset: "M4 13a8 8 0 0 1 16 0v4a2 2 0 0 1-2 2h-2v-6h4 M4 17v-4h4v6H6a2 2 0 0 1-2-2z M14 21h2a4 4 0 0 0 4-4",
  clock: "M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18z M12 7v5l3 2",
  monitor: "M3 5h18v11H3z M8 21h8 M12 16v5",
  wrench: "M14.7 6.3a4 4 0 0 0-5 5L4 17v3h3l5.7-5.7a4 4 0 0 0 5-5l-3 3-3-3 3-3z",
  mail: "M4 6h16v12H4z M4 7l8 6 8-6",
  phone: "M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 3.9 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.7.6 2.5a2 2 0 0 1-.5 2.1L8.8 9.5a16 16 0 0 0 5.7 5.7l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.6.5 2.5.6a2 2 0 0 1 1.7 2z",
  shield: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  remote: "M8 2h8a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z M12 6h.1 M10 10h4 M10 14h4 M10 18h4",
} as const;

const supportTypes = [
  { title: "Storing of foutmelding", text: "Meld wat u ziet, op welk scherm het gebeurt en sinds wanneer.", icon: "monitor", tone: "blue" },
  { title: "Wijziging of beheer", text: "Voor aanpassingen in content, playlists, gebruikers of locaties.", icon: "remote", tone: "teal" },
  { title: "Technische hulp", text: "Ondersteuning bij players, netwerk, displays, koppelingen of software.", icon: "wrench", tone: "amber" },
] as const;

const expectations = [
  "Support op werkdagen van 09:00 tot 17:30.",
  "Bij storingen streven we naar een reactie binnen 4 uur op werkdagen.",
  "Ondersteuning kan op afstand, telefonisch of indien nodig op locatie.",
  "Vermeld locatie, schermnaam en eventueel een foto van de melding.",
] as const;
---

<BaseLayout
  title="Service & Support | ClubDisplay"
  description="Support aanvraag voor ClubDisplay. Hulp nodig bij digital signage, hotel TV, narrowcasting, menuborden of schermbeheer? Dien een supportverzoek in."
  canonical="https://clubdisplay.nl/service-support/"
  currentPath="/service-support/"
>
  <section class="support-hero">
    <div class="container support-hero-grid">
      <div class="support-copy">
        <span class="eyebrow">Service & Support</span>
        <h1>Hulp nodig met uw ClubDisplay systeem?</h1>
        <p>
          Heeft u een vraag, storing of wijziging voor uw narrowcasting, hotel-tv, digitaal menubord of scherminstallatie? Vul het supportformulier in, dan pakken wij uw verzoek zo gericht mogelijk op.
        </p>
      </div>
      <aside class="support-contact-card" aria-label="Support contactgegevens">
        <span class="contact-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><path d={iconPaths.headset} /></svg>
        </span>
        <h2>Supportdesk</h2>
        <p>Bereikbaar op werkdagen van 09:00 tot 17:30.</p>
        <div class="contact-lines">
          <a href="mailto:support@clubdisplay.nl">
            <svg viewBox="0 0 24 24" fill="none"><path d={iconPaths.mail} /></svg>
            support@clubdisplay.nl
          </a>
          <a href="tel:+31851303088">
            <svg viewBox="0 0 24 24" fill="none"><path d={iconPaths.phone} /></svg>
            085 130 30 88
          </a>
        </div>
      </aside>
    </div>
  </section>

  <section class="support-section">
    <div class="container support-types-grid">
      {supportTypes.map((item) => (
        <article class:list={["support-type-card", `tone-${item.tone}`]}>
          <span class="card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none"><path d={iconPaths[item.icon]} /></svg>
          </span>
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="support-section section-alt">
    <div class="container support-layout">
      <div class="support-info">
        <span class="eyebrow">Aanvraag indienen</span>
        <h2>Beschrijf kort waar u hulp bij nodig heeft</h2>
        <p>
          Hoe duidelijker de melding, hoe sneller we kunnen meekijken. Noem bij voorkeur de locatie, het scherm of systeem, de foutmelding en of het probleem op een of meerdere schermen speelt.
        </p>
        <ul class="expectation-list">
          {expectations.map((item) => (
            <li>
              <span aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d={iconPaths.clock} /></svg>
              </span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <section class="support-form-card" aria-labelledby="support-form-title">
        <div class="support-form-copy">
          <h2 id="support-form-title">Supportverzoek indienen</h2>
          <p>Vul het formulier in. Ons supportteam neemt daarna contact met u op.</p>
        </div>
        <div id="hubspot-support-form" class="support-form"></div>
      </section>
    </div>
  </section>

  <section class="support-section">
    <div class="container contract-panel">
      <div>
        <span class="eyebrow">Onderhoud</span>
        <h2>Servicecontracten en beheer</h2>
      </div>
      <p>
        Voor locaties waar schermen dagelijks belangrijk zijn, kunnen we onderhoud en beheer structureel inrichten. Denk aan ondersteuning op afstand, periodieke controle, contentwijzigingen, monitoring, vervangingshardware en prioriteit bij storingen. We adviseren welk serviceniveau past bij uw locatie en gebruik.
      </p>
      <a href="/contact/" class="btn btn-outline">Vraag advies over support</a>
    </div>
  </section>
</BaseLayout>

<script is:inline charset="utf-8" type="text/javascript" src="https://js-eu1.hsforms.net/forms/embed/v2.js"></script>
<script is:inline>
  window.addEventListener("load", function () {
    if (!window.hbspt || !document.querySelector("#hubspot-support-form")) return;

    window.hbspt.forms.create({
      portalId: "25590166",
      formId: "d2bd47b0-c3c4-40a4-90e3-8b3345dd6f32",
      region: "eu1",
      target: "#hubspot-support-form"
    });
  });
</script>

<style>
  .support-hero {
    padding: 5rem 0 4rem;
    background: linear-gradient(180deg, #f3f8fd 0%, #fff 100%);
  }

  .support-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 3rem;
    align-items: center;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--primary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .support-copy h1 {
    max-width: 780px;
    font-size: clamp(2.4rem, 4.6vw, 4.4rem);
    line-height: 1;
    margin-bottom: 1.25rem;
  }

  .support-copy p {
    max-width: 680px;
    font-size: 1.08rem;
  }

  .support-contact-card,
  .support-type-card,
  .support-form-card,
  .contract-panel {
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.28);
    border-radius: 20px;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.06);
  }

  .support-contact-card {
    padding: 1.6rem;
  }

  .support-contact-card h2 {
    margin: 1rem 0 0.5rem;
    font-size: 1.3rem;
  }

  .support-contact-card p {
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .contact-icon,
  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 14px;
    color: var(--brand-accent);
    background: var(--primary-light);
  }

  .contact-icon svg,
  .card-icon svg,
  .contact-lines svg,
  .expectation-list svg {
    width: 1.35rem;
    height: 1.35rem;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .contact-lines {
    display: grid;
    gap: 0.7rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-light);
  }

  .contact-lines a {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--text);
    font-weight: 700;
  }

  .contact-lines svg {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--primary);
  }

  .support-section {
    padding: 4.5rem 0;
    background: #fff;
  }

  .section-alt {
    background: var(--bg-alt);
  }

  .support-types-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .support-type-card {
    position: relative;
    display: grid;
    align-content: start;
    gap: 0.8rem;
    min-height: 190px;
    padding: 1.45rem;
    overflow: hidden;
  }

  .support-type-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    background: var(--card-accent, var(--primary));
  }

  .support-type-card h2 {
    margin: 0;
    font-size: 1.08rem;
  }

  .support-type-card p {
    margin: 0;
    font-size: 0.92rem;
  }

  .tone-blue {
    --card-accent: var(--brand-accent);
  }

  .tone-teal {
    --card-accent: #0d9488;
  }

  .tone-teal .card-icon {
    color: #0f766e;
    background: #ccfbf1;
  }

  .tone-amber {
    --card-accent: #f59e0b;
  }

  .tone-amber .card-icon {
    color: #b45309;
    background: #fef3c7;
  }

  .support-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(420px, 1.18fr);
    gap: 2rem;
    align-items: start;
  }

  .support-info {
    position: sticky;
    top: 6rem;
  }

  .support-info h2,
  .contract-panel h2 {
    font-size: clamp(1.75rem, 2.8vw, 2.8rem);
    line-height: 1.12;
  }

  .expectation-list {
    display: grid;
    gap: 0.85rem;
    margin: 1.75rem 0 0;
    padding: 0;
    list-style: none;
  }

  .expectation-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: start;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .expectation-list span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    color: var(--brand-accent);
    background: var(--primary-light);
  }

  .expectation-list svg {
    width: 1rem;
    height: 1rem;
  }

  .support-form-card {
    padding: 2rem;
  }

  .support-form-copy {
    max-width: 720px;
    margin-bottom: 1.5rem;
  }

  .support-form-copy h2 {
    margin-top: 0;
  }

  .support-form-copy p {
    margin-bottom: 0;
  }

  .support-form {
    min-height: 360px;
  }

  .contract-panel {
    display: grid;
    grid-template-columns: minmax(300px, 0.85fr) minmax(320px, 1fr);
    gap: 1.75rem 2.25rem;
    align-items: center;
    padding: 2rem;
  }

  .contract-panel .btn {
    justify-self: start;
    grid-column: 2;
  }

  .contract-panel p {
    margin: 0;
  }

  @media (max-width: 1000px) {
    .support-hero-grid,
    .support-layout,
    .contract-panel {
      grid-template-columns: 1fr;
    }

    .contract-panel .btn {
      grid-column: auto;
    }

    .support-info {
      position: static;
    }

    .support-types-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .support-hero,
    .support-section {
      padding: 3.25rem 0;
    }

    .support-copy h1 {
      font-size: clamp(2.35rem, 12vw, 3.3rem);
    }

    .support-contact-card,
    .support-form-card,
    .contract-panel {
      padding: 1.35rem;
    }
  }
</style>
