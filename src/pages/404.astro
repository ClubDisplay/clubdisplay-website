---
<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pagina niet gevonden | ClubDisplay</title>
  <meta name="robots" content="noindex, follow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f9fafb; color: #1f2937; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem; }
    .card { background: white; border-radius: 1rem; padding: 3rem; max-width: 600px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    h1 { font-size: 6rem; color: var(--primary); margin-bottom: 0; line-height: 1; }
    h2 { font-size: 1.5rem; margin-bottom: 1rem; }
    p { color: #6b7280; margin-bottom: 2rem; }
    a { display: inline-block; background: var(--primary); color: white; padding: 0.75rem 1.5rem; border-radius: 0.5rem; text-decoration: none; font-weight: 600; }
    a:hover { background: #0f3b9e; }
    hr { margin: 2rem 0; border: none; border-top: 1px solid #e5e7eb; }
    .links { text-align: left; }
    .links a { display: block; background: none; color: var(--primary); padding: 0.25rem 0; font-weight: 400; font-size: 0.875rem; }
    .links a:hover { text-decoration: underline; background: none; }
  </style>
</head>
<body>
  <div class="card">
    <h1>404</h1>
    <h2>Pagina niet gevonden</h2>
    <p>Deze pagina bestaat niet of is verplaatst.</p>
    <a href="/">Terug naar home</a>
    <hr />
    <div class="links">
      <p style="font-weight: 600; margin-bottom: 0.5rem;">Wellicht zoekt u een van deze pagina's:</p>
      {pages.map(p => <a href={p.slug}>{p.title}</a>)}
    </div>
  </div>
</body>
</html>
