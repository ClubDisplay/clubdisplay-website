---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const allCases = await getCollection("cases");
allCases.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const recentCases = allCases.slice(0, 6);
---

<BaseLayout title="Home" description="ClubDisplay is een full-service creatief Digital Signage bureau. Specialist in narrowcasting, hospitality TV, digitale menuborden, wayfinding en room signage." ogImage="https://clubdisplay.nl/images/og-home.jpg">
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <span class="hero-badge">Narrowcasting Specialist</span>
        <h1>Digital Signage dat <span class="text-accent">écht opvalt</span></h1>
        <p>Wij helpen organisaties met het inrichten van de perfecte narrowcasting oplossing. Van ontwerp tot installatie, volledig op maat.</p>
        <div class="hero-btns">
          <a href="/contact/" class="btn btn-lg">Neem contact op</a>
          <a href="/probeer-30-dagen-gratis/" class="btn btn-outline btn-lg">30 dagen gratis</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Onze expertises</h2>
        <p>Van ontwerp tot installatie — wij leveren complete digital signage oplossingen</p>
      </div>
      <div class="grid-3">
        <a href="/narrowcasting/" class="card">
          <div class="card-icon">🖥️</div>
          <h3>Narrowcasting</h3>
          <p>Gebruiksvriendelijke software voor digital signage. Beheer eenvoudig uw schermen en plan content vooruit.</p>
          <span class="card-link">Meer informatie &rarr;</span>
        </a>
        <a href="/lg-procentric/" class="card">
          <div class="card-icon">📺</div>
          <h3>Hospitality TV</h3>
          <p>LG Pro:Centric, Google Chromecast voor hotels en IPTV voor de ultieme gastervaring.</p>
          <span class="card-link">Meer informatie &rarr;</span>
        </a>
        <a href="/digitale-menuborden/" class="card">
          <div class="card-icon">📋</div>
          <h3>Digitale menuborden</h3>
          <p>Interactieve menuborden die opvallen. Eenvoudig zelf te beheren en aan te passen.</p>
          <span class="card-link">Meer informatie &rarr;</span>
        </a>
        <a href="/wayfinding-en-room-signage/" class="card">
          <div class="card-icon">📍</div>
          <h3>Wayfinding & Room Signage</h3>
          <p>Duidelijke visuele aanwijzingen voor vergaderruimten, evenementen en gebouwen.</p>
          <span class="card-link">Meer informatie &rarr;</span>
        </a>
        <a href="/etalageschermen/" class="card">
          <div class="card-icon">🪟</div>
          <h3>Etalageschermen</h3>
          <p>Val op in de winkelstraat met dynamische etalageschermen die 24/7 de aandacht trekken.</p>
          <span class="card-link">Meer informatie &rarr;</span>
        </a>
        <a href="/draadloos-presenteren/" class="card">
          <div class="card-icon">🔄</div>
          <h3>Draadloos presenteren</h3>
          <p>LG One:Quick Share voor moeiteloos screen sharing zonder gedoe met kabels.</p>
          <span class="card-link">Meer informatie &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Recente projecten</h2>
        <p>Bekijk een selectie van onze uitgevoerde digital signage projecten</p>
      </div>
      <div class="case-grid">
        {recentCases.map(c => (
          <a href={`/project/${c.slug}/`} class="case-card">
            {c.data.image && <img src={c.data.image} alt={c.data.title} width="510" height="382" loading="lazy" />}
            <div class="case-card-body">
              <h3>{c.data.title}</h3>
              <p class="case-date">{new Date(c.data.pubDate).toLocaleDateString("nl-NL", { year: "numeric", month: "long", day: "numeric" })}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center" style="margin-top: 2.5rem;">
        <a href="/cases/" class="btn">Bekijk alle cases &rarr;</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Digital Signage per segment</h2>
        <p>Voor elke branche de juiste oplossing</p>
      </div>
      <div class="segment-grid">
        <div class="segment-item">
          <div class="segment-icon">🏨</div>
          <h3>Hotel</h3>
          <p>Maak het verblijf van uw gasten compleet</p>
        </div>
        <div class="segment-item">
          <div class="segment-icon">🛍️</div>
          <h3>Retail</h3>
          <p>Stimuleer uw omzet met digitale signage</p>
        </div>
        <div class="segment-item">
          <div class="segment-icon">🍽️</div>
          <h3>Café & Restaurant</h3>
          <p>Informeer en amuseer uw gasten</p>
        </div>
        <div class="segment-item">
          <div class="segment-icon">🎓</div>
          <h3>Onderwijs</h3>
          <p>Informeer leerlingen en studenten</p>
        </div>
        <div class="segment-item">
          <div class="segment-icon">🏢</div>
          <h3>Kantoor</h3>
          <p>Informeer en bind uw medewerkers</p>
        </div>
        <div class="segment-item">
          <div class="segment-icon">❤️</div>
          <h3>Zorg & Welzijn</h3>
          <p>Wachttijdverzachting voor patiënten</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Wat onze klanten zeggen</h2>
      </div>
      <div class="testimonial-grid">
        <blockquote class="testimonial-card">
          <p>"Delivered a very successful Digital Signage solution at the Hotel Okura Amsterdam. Everybody is very happy with the new system."</p>
          <cite><strong>Marc Rijnders</strong>, IT Manager, Hotel Okura Amsterdam</cite>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>"Het Narrowcasting systeem is gemakkelijk in gebruik en als we iets niet begrijpen is de ondersteuning ook top!"</p>
          <cite><strong>Donald de Vogel</strong>, Eigenaar, Karwei Bouwmarkt</cite>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>"We zijn erg tevreden over de support. Alles wordt snel opgepakt en de communicatie verloopt altijd prima!"</p>
          <cite><strong>Denni Wang</strong>, Manager, 171. Urban Design Hotel</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Onze partners</h2>
      </div>
      <div class="partner-grid">
        <div class="partner-item">Otrum</div>
        <div class="partner-item">LG</div>
        <div class="partner-item">Samsung</div>
        <div class="partner-item">Philips</div>
        <div class="partner-item">TigerTMS</div>
        <div class="partner-item">Ariane Systems</div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Advies nodig? Wij helpen je graag!</h2>
      <p>Voor elke plaats en situatie bieden wij een geschikte oplossing voor narrowcasting. Bel of mail ons geheel vrijblijvend voor een afspraak.</p>
      <div class="cta-contact">
        <a href="/contact/" class="btn btn-lg">Neem contact op</a>
        <span class="cta-phone">T. +31 (0)85 760 2202</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0 4rem;
    background: linear-gradient(135deg, #1a56db 0%, #06b6d4 100%);
    color: white;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute; inset: 0;
    background: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.08) 0%, transparent 60%);
  }
  .hero-content { position: relative; max-width: 720px; margin: 0 auto; text-align: center; }
  .hero-badge {
    display: inline-block; background: rgba(255,255,255,0.15); backdrop-filter: blur(8px);
    padding: 0.375rem 1rem; border-radius: 999px; font-size: 0.813rem; font-weight: 600;
    margin-bottom: 1.5rem; letter-spacing: 0.02em;
  }
  .hero h1 { font-size: 3rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.15; color: white; }
  .text-accent { color: #a5f3fc; }
  .hero p { font-size: 1.125rem; opacity: 0.9; max-width: 600px; margin: 0 auto 2rem; color: rgba(255,255,255,0.9); }
  .hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-outline { background: transparent; color: white; border: 2px solid rgba(255,255,255,0.5); }
  .btn-outline:hover { background: rgba(255,255,255,0.1); border-color: white; }

  .section { padding: 5rem 0; }
  .section-alt { background: #f9fafb; }
  .section-header { text-align: center; max-width: 650px; margin: 0 auto 3rem; }
  .section-header h2 { margin-top: 0; }
  .section-header p { font-size: 1.125rem; }

  .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
  .card { display: flex; flex-direction: column; background: white; border-radius: var(--radius-lg); padding: 2rem; border: 1px solid var(--border); transition: box-shadow 0.2s, transform 0.2s; text-decoration: none; color: inherit; }
  .card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); color: inherit; }
  .card-icon { font-size: 2rem; margin-bottom: 1rem; }
  .card h3 { margin-top: 0; }
  .card p { font-size: 0.938rem; flex: 1; }
  .card-link { color: var(--primary); font-weight: 600; font-size: 0.875rem; margin-top: 1rem; }

  .case-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
  .case-card { display: block; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border); text-decoration: none; color: inherit; transition: box-shadow 0.2s, transform 0.2s; }
  .case-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); color: inherit; }
  .case-card img { width: 100%; height: 220px; object-fit: cover; border-radius: 0; }
  .case-card-body { padding: 1.25rem; }
  .case-card-body h3 { margin: 0 0 0.5rem; font-size: 1rem; line-height: 1.3; }
  .case-date { font-size: 0.813rem; color: var(--text-muted); margin: 0; }

  .segment-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 1.5rem; text-align: center; }
  .segment-item { padding: 2rem 1.5rem; border-radius: var(--radius-lg); background: white; border: 1px solid var(--border); transition: border-color 0.2s, box-shadow 0.2s; }
  .segment-item:hover { border-color: var(--primary); box-shadow: 0 4px 12px rgba(26,86,219,0.1); }
  .segment-icon { font-size: 2rem; margin-bottom: 0.75rem; }
  .segment-item h3 { margin-top: 0; font-size: 1.1rem; }
  .segment-item p { font-size: 0.875rem; margin: 0; }

  .testimonial-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
  .testimonial-card { background: white; border-radius: var(--radius-lg); padding: 2rem; border: 1px solid var(--border); font-style: italic; }
  .testimonial-card p { font-size: 0.938rem; color: var(--text-light); margin-bottom: 1.5rem; }
  .testimonial-card cite { font-style: normal; font-size: 0.813rem; color: var(--text-muted); }
  .testimonial-card cite strong { color: var(--text); display: block; }

  .partner-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; text-align: center; }
  .partner-item { padding: 1.5rem; border-radius: var(--radius); background: white; border: 1px solid var(--border); font-weight: 600; font-size: 1.125rem; display: flex; align-items: center; justify-content: center; min-height: 70px; transition: border-color 0.2s; }
  .partner-item:hover { border-color: var(--primary); }

  .cta-section { text-align: center; background: var(--primary); color: white; padding: 4rem 0; }
  .cta-section h2 { color: white; margin-top: 0; }
  .cta-section p { opacity: 0.9; max-width: 600px; margin: 0 auto 2rem; color: rgba(255,255,255,0.9); }
  .cta-contact { display: flex; align-items: center; justify-content: center; gap: 1.5rem; flex-wrap: wrap; }
  .cta-phone { font-weight: 600; font-size: 1.125rem; }
  .cta-section .btn { background: white; color: var(--primary); }
  .cta-section .btn:hover { background: #f3f4f6; }
  .text-center { text-align: center; }

  @media (max-width: 768px) {
    .hero { padding: 3rem 0; }
    .hero h1 { font-size: 2rem; }
    .hero p { font-size: 1rem; }
    .section { padding: 3rem 0; }
    .section-header { margin-bottom: 2rem; }
  }
</style>
