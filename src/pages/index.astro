---
import BaseLayout from "../layouts/BaseLayout.astro";

const iconPaths = {
  tv: "M3 5h18v11H3z M8 21h8 M12 16v5",
  play: "M8 5v14l11-7-11-7z",
  menu: "M4 6h16 M4 12h16 M4 18h10",
  software: "M4 5h16v14H4z M8 9h4 M8 13h8 M8 17h6",
  display: "M3 5h18v11H3z M7 21h10 M12 16v5",
  map: "M9 18l-6 3V6l6-3 6 3 6-3v15l-6 3-6-3z M9 3v15 M15 6v15",
  shop: "M4 10h16l-1-6H5l-1 6z M5 10v10h14V10 M8 14h8",
  sun: "M12 4V2 M12 22v-2 M4.93 4.93 3.52-1.41 M19.07 19.07l-1.41-1.41 M4 12H2 M22 12h-2 M4.93 19.07l1.41-1.41 M19.07 4.93l-1.41 1.41 M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z",
  wrench: "M14.7 6.3a4 4 0 0 0-5 5L4 17v3h3l5.7-5.7a4 4 0 0 0 5-5l-3 3-3-3 3-3z",
  shield: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  link: "M10 13a5 5 0 0 0 7.1 0l2-2a5 5 0 0 0-7.1-7.1l-1.1 1.1 M14 11a5 5 0 0 0-7.1 0l-2 2a5 5 0 0 0 7.1 7.1l1.1-1.1",
  spark: "M12 2l1.8 6.2L20 10l-6.2 1.8L12 18l-1.8-6.2L4 10l6.2-1.8L12 2z",
} as const;

const solutions = [
  {
    title: "Hospitality TV & IPTV",
    eyebrow: "Hotels en zorg",
    text: "Professionele hotel-tv, IPTV, casting, PMS-koppelingen en centraal beheer voor kamers, receptie en gastinformatie.",
    href: "/zakelijke-iptv-voor-hotels-en-bedrijven/",
    image: "/images/iptv/Zoomers.jpg",
    icon: "tv",
    tone: "blue",
  },
  {
    title: "Interactieve Televisie",
    eyebrow: "TV-zenders",
    text: "Zakelijke interactieve televisie met zenderpakketten via LG Pro:Centric, settopbox of complete BNBTV hospitality tv.",
    href: "/interactieve-televisie/",
    image: "/images/iptv/IPTV_KPN.jpg",
    icon: "play",
    tone: "teal",
  },
  {
    title: "Digitale menuborden",
    eyebrow: "Horeca en food",
    text: "Digitale menuborden voor restaurants, hotels, cafetaria’s en coffeeshops, inclusief dagdelen en kassakoppeling.",
    href: "/digitale-menuborden/",
    image: "/images/digitale-menuborden/piramide-baliescherm.jpg",
    icon: "menu",
    tone: "amber",
  },
  {
    title: "Narrowcasting software",
    eyebrow: "Beheer en planning",
    text: "Schermen centraal vullen met campagnes, playlists, data, AI-koppelingen, planning en automatische updates.",
    href: "/narrowcasting/",
    image: "/images/digitale-menuborden/grasscompany.jpg",
    icon: "software",
    tone: "violet",
  },
  {
    title: "Digital signage hardware",
    eyebrow: "Displays en players",
    text: "Professionele displays, mediaspelers, beugels, netwerkadvies, installatie en technische oplevering.",
    href: "/displays/",
    image: "/images/displays/HennyRits_HighBrightness.jpg",
    icon: "display",
    tone: "blue",
  },
  {
    title: "Wayfinding & room signage",
    eyebrow: "Routes en zalen",
    text: "Digitale bewegwijzering, room signage, zaalstatus en koppelingen met Outlook, Google Calendar of signage software.",
    href: "/wayfinding-en-room-signage/",
    image: "/images/wayfinding/OtrumMeeting.jpg",
    icon: "map",
    tone: "teal",
  },
  {
    title: "Coffeeshop signage",
    eyebrow: "Prijslijsten en touch",
    text: "Digitale prijslijsten, balieschermen en info touch displays voor coffeeshops, met POS-koppeling via JSON/API.",
    href: "/coffeeshop-signage/",
    image: "/images/coffeeshop/infotouch_Riskey.jpg",
    icon: "shop",
    tone: "amber",
  },
  {
    title: "Etalageschermen",
    eyebrow: "High-brightness",
    text: "High-brightness displays van 2.500 tot 4.000 cd/m2 voor winkelruiten, acties, campagnes en zichtbaarheid.",
    href: "/etalageschermen/",
    image: "/images/etalageschermen/henny-rits-highbrightness.jpg",
    icon: "sun",
    tone: "violet",
  },
] as const;

const proofPoints = [
  { title: "Advies op locatie", text: "We kijken naar doel, publiek, plaatsing en beheer.", icon: "spark", tone: "blue" },
  { title: "Hardware en software", text: "Displays, players, platform, content en koppelingen.", icon: "display", tone: "teal" },
  { title: "Installatie en support", text: "Montage, inrichting, training, beheer en service.", icon: "wrench", tone: "amber" },
] as const;

const process = [
  { step: "01", title: "We bepalen de toepassing", text: "Hospitality TV, menubord, narrowcasting, etalage, wayfinding of coffeeshop signage: eerst moet helder zijn wat het scherm moet oplossen." },
  { step: "02", title: "We kiezen de juiste techniek", text: "We adviseren over schermtype, helderheid, player, software, netwerk, koppelingen, montage en contentbeheer." },
  { step: "03", title: "We leveren werkend op", text: "ClubDisplay verzorgt installatie, inrichting, contentbasis, uitleg en support, zodat uw team ermee door kan." },
] as const;

const cases = [
  {
    title: "Zoomers Strandhuisjes",
    text: "Hospitality TV, Chromecast en gastinformatie voor strandhuisjes.",
    href: "/project/clubdisplay-moderniseert-zoomers-strandhuisjes-met-lg-hospitality-tvs-en-chromecast/",
    image: "/images/cases/zoomers_strandhuisjes.jpg",
  },
  {
    title: "Coffeeshop Piramide",
    text: "Digitale prijslijsten en baliescherm voor actuele productinformatie.",
    href: "/project/cannabiswinkel-piramide-bussum/",
    image: "/images/cases/piramide01.jpg",
  },
  {
    title: "Hotel Wren Urban Nest",
    text: "Hotel TV en hospitality content voor een moderne hotelervaring.",
    href: "/project/hotel-wren-urban-nest-dublin-ierland/",
    image: "/images/wren.jpeg",
  },
] as const;

const testimonials = [
  {
    quote: "Delivered a very successful Digital Signage solution at the Hotel Okura Amsterdam. Everybody is very happy with the new system.",
    name: "Marc Rijnders",
    role: "IT Manager, Hotel Okura Amsterdam",
    image: "/images/testimonials/marc-rijnders-okura.jpeg",
    alt: "Marc Rijnders van Hotel Okura Amsterdam",
    tone: "blue",
  },
  {
    quote: "Na het eerste telefoongesprek was alles meteen duidelijk en snel geregeld. Het narrowcasting systeem is gemakkelijk in gebruik en als we iets niet begrijpen is de ondersteuning top.",
    name: "Donald de Vogel",
    role: "Eigenaar, Karwei Bouwmarkt",
    image: "/images/testimonials/karwei-berkel-rodenrijs.jpg",
    alt: "Karwei Bouwmarkt Berkel en Rodenrijs",
    tone: "navy",
  },
  {
    quote: "ClubDisplay heeft voor ons een succesvolle Chromecast oplossing en een digitale informatiekiosk opgeleverd. De support is snel en de communicatie verloopt altijd prima.",
    name: "Denni Wang",
    role: "Manager, 171. Urban Design Hotel",
    image: "/images/testimonials/denni-wang-171.jpeg",
    alt: "Denni Wang van 171 Urban Design Hotel",
    tone: "teal",
  },
  {
    quote: "Met ClubDisplay heeft de receptie een professionele uitstraling gekregen en is het scherm een echte blikvanger voor gasten, sponsoren en relaties.",
    name: "Cleo Prudon",
    role: "Marketing en Event manager, Golfbaan Bentwoud",
    image: "/images/testimonials/cleo-prudon-bentwoud.jpg",
    alt: "Cleo Prudon van Golfbaan Bentwoud",
    tone: "amber",
  },
] as const;
---

<BaseLayout
  title="Digital signage, narrowcasting en hospitality TV specialist | ClubDisplay"
  description="ClubDisplay ontwerpt, levert en beheert digital signage, narrowcasting, hospitality TV, digitale menuborden, wayfinding en professionele displays."
  canonical="https://clubdisplay.nl/"
  currentPath="/"
>
  <section class="home-hero">
    <div class="home-hero-bg" aria-hidden="true"></div>
    <div class="container home-hero-content">
      <span class="eyebrow">ClubDisplay narrowcasting & digital signage</span>
      <h1>Schermen die uw locatie slimmer laten communiceren</h1>
      <p>
        Van hospitality TV en interactieve televisie tot digitale menuborden, narrowcasting software, coffeeshop signage, wayfinding en etalageschermen. ClubDisplay ontwerpt, levert en beheert professionele schermoplossingen voor locaties waar gasten, klanten en bezoekers kijken.
      </p>
      <div class="hero-actions">
        <a href="/contact/#contactformulier" class="btn btn-lg">Contact opnemen</a>
        <a href="#oplossingen" class="btn btn-lg btn-white">Bekijk oplossingen</a>
      </div>
    </div>
  </section>

  <section class="proof-strip" aria-label="Waarom ClubDisplay">
    <div class="container proof-grid">
      {proofPoints.map((item) => (
        <article class:list={["proof-card", `tone-${item.tone}`]}>
          <span class="card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none"><path d={iconPaths[item.icon]} /></svg>
          </span>
          <div>
            <strong>{item.title}</strong>
            <span>{item.text}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="home-section" id="oplossingen">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Onze oplossingen</span>
        <h2>Een passende schermoplossing voor elke locatie</h2>
        <p>
          Kies de toepassing die past bij uw situatie. Iedere oplossing is opgebouwd rond professioneel advies, betrouwbare hardware, passende software, content en support.
        </p>
      </div>
      <div class="solutions-grid">
        {solutions.map((solution) => (
          <a href={solution.href} class:list={["solution-card", `tone-${solution.tone}`]}>
            <figure>
              <img src={solution.image} alt={`${solution.title} van ClubDisplay`} loading="lazy" decoding="async" />
            </figure>
            <div class="solution-content">
              <span class="solution-eyebrow">{solution.eyebrow}</span>
              <span class="card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d={iconPaths[solution.icon]} /></svg>
              </span>
              <h3>{solution.title}</h3>
              <p>{solution.text}</p>
              <span class="text-link">
                Bekijk oplossing
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14 M13 6l6 6-6 6" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section section-alt">
    <div class="container split-grid">
      <div>
        <span class="eyebrow">Van advies tot beheer</span>
        <h2>Een scherm is pas waardevol als content, techniek en beheer samen kloppen</h2>
      </div>
      <div class="process-list">
        {process.map((item) => (
          <article class="process-card">
            <span>{item.step}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container cases-layout">
      <div class="cases-copy">
        <span class="eyebrow">Projecten</span>
        <h2>Gerealiseerde digital signage projecten</h2>
        <p>
          Bekijk hoe ClubDisplay schermoplossingen inzet bij hotels, horeca, coffeeshops, retail en publieke locaties.
        </p>
        <a href="/cases/" class="btn btn-outline">Bekijk alle projecten</a>
      </div>
      <div class="case-grid">
        {cases.map((item) => (
          <a href={item.href} class="case-card">
            <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section testimonial-section">
    <div class="container">
      <div class="section-head testimonial-head">
        <span class="eyebrow">Wat klanten zeggen</span>
        <h2>Ervaringen met ClubDisplay</h2>
        <p>
          Van hotel en retail tot sportlocatie: klanten waarderen vooral de combinatie van advies, gebruiksgemak, installatie en snelle support.
        </p>
      </div>
      <div class="testimonial-grid">
        {testimonials.map((item) => (
          <article class:list={["testimonial-card", `review-${item.tone}`]}>
            <div class="testimonial-avatar">
              <img src={item.image} alt={item.alt} loading="lazy" decoding="async" />
            </div>
            <div class="testimonial-content">
              <span class="quote-mark" aria-hidden="true">“</span>
              <footer>
                <strong>{item.name}</strong>
                <span>{item.role}</span>
              </footer>
              <blockquote>{item.quote}</blockquote>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-cta">
    <div class="container cta-inner">
      <span class="eyebrow">Samen kijken?</span>
      <h2>Wilt u weten welke oplossing past bij uw locatie?</h2>
      <p>
        We denken graag mee over digital signage, narrowcasting, hotel TV, menuborden, etalageschermen of een combinatie van oplossingen.
      </p>
      <div class="hero-actions">
        <a href="/contact/#contactformulier" class="btn btn-lg btn-white">Contact opnemen</a>
        <a href="/plan-jouw-gesprek/" class="btn btn-lg btn-outline-white">Plan adviesgesprek</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    min-height: calc(100vh - 4.75rem);
    display: grid;
    align-items: center;
    overflow: hidden;
    color: #fff;
    background: #0f172a;
  }

  .home-hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(15, 23, 42, 0.92) 0%, rgba(15, 23, 42, 0.74) 42%, rgba(15, 23, 42, 0.36) 100%),
      url("/images/hotel-lobby-hero.jpg") center / cover;
  }

  .home-hero-content {
    position: relative;
    z-index: 1;
    padding: 6rem 0 8rem;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--primary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .home-hero .eyebrow,
  .home-cta .eyebrow {
    color: #9fc4e7;
  }

  .home-hero h1 {
    max-width: 820px;
    color: #fff;
    font-size: clamp(3rem, 7vw, 6.4rem);
    line-height: 0.94;
    margin-bottom: 1.5rem;
  }

  .home-hero p {
    max-width: 690px;
    color: #e2e8f0;
    font-size: 1.12rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .btn-white {
    background: #fff;
    color: var(--primary) !important;
  }

  .btn-white:hover {
    background: var(--primary-light);
    color: var(--primary-dark) !important;
  }

  .proof-strip {
    position: relative;
    z-index: 2;
    background: #fff;
    border-bottom: 1px solid var(--border-light);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    transform: translateY(-1.5rem);
  }

  .proof-card {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    padding: 1rem;
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.28);
    border-radius: 16px;
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
  }

  .proof-card div {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  .proof-card strong {
    color: var(--text);
    font-size: 0.95rem;
  }

  .proof-card span:not(.card-icon) {
    color: var(--text-secondary);
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .home-section {
    padding: 6rem 0;
    background: #fff;
  }

  .section-alt {
    background: var(--bg-alt);
  }

  .section-head {
    max-width: 820px;
    margin-bottom: 2.5rem;
  }

  .section-head h2,
  .split-grid h2,
  .cases-copy h2,
  .home-cta h2 {
    font-size: clamp(2rem, 3.6vw, 3.5rem);
    line-height: 1.06;
  }

  .section-head p,
  .cases-copy p,
  .home-cta p {
    font-size: 1.03rem;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .solution-card {
    position: relative;
    display: grid;
    min-height: 460px;
    color: inherit;
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.06);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .solution-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    z-index: 2;
    background: var(--card-accent, var(--primary));
  }

  .solution-card:hover {
    transform: translateY(-5px);
    border-color: rgba(var(--primary-rgb), 0.26);
    box-shadow: 0 28px 70px rgba(15, 23, 42, 0.12);
  }

  .solution-card figure {
    height: 180px;
    overflow: hidden;
    background: #e2e8f0;
  }

  .solution-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 240ms ease;
  }

  .solution-card:hover img {
    transform: scale(1.04);
  }

  .solution-content {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    padding: 1.25rem;
  }

  .solution-eyebrow {
    color: var(--card-accent, var(--primary));
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .solution-card h3 {
    margin: 0;
    font-size: 1.12rem;
    line-height: 1.25;
  }

  .solution-card p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.58;
  }

  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.4rem;
    color: var(--primary);
    font-weight: 800;
    font-size: 0.9rem;
  }

  .text-link svg {
    width: 1rem;
    height: 1rem;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 14px;
    color: var(--brand-accent);
    background: var(--primary-light);
  }

  .card-icon svg {
    width: 1.35rem;
    height: 1.35rem;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tone-blue {
    --card-accent: var(--brand-accent);
  }

  .tone-teal {
    --card-accent: #0d9488;
  }

  .tone-teal .card-icon {
    color: #0f766e;
    background: #ccfbf1;
  }

  .tone-amber {
    --card-accent: #f59e0b;
  }

  .tone-amber .card-icon {
    color: #b45309;
    background: #fef3c7;
  }

  .tone-violet {
    --card-accent: #7c3aed;
  }

  .tone-violet .card-icon {
    color: #6d28d9;
    background: #ede9fe;
  }

  .split-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
    gap: 4rem;
    align-items: start;
  }

  .process-list {
    display: grid;
    gap: 1rem;
  }

  .process-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding: 1.2rem;
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 18px;
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.05);
  }

  .process-card > span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 999px;
    color: var(--brand-accent);
    background: var(--primary-light);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .process-card h3 {
    margin: 0 0 0.3rem;
    font-size: 1.05rem;
  }

  .process-card p {
    margin: 0;
    font-size: 0.92rem;
  }

  .cases-layout {
    display: grid;
    grid-template-columns: 0.72fr 1.28fr;
    gap: 2rem;
    align-items: start;
  }

  .cases-copy {
    position: sticky;
    top: 6rem;
  }

  .case-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .case-card {
    position: relative;
    min-height: 360px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    border-radius: 22px;
    color: #fff;
    background: #0f172a;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.12);
  }

  .case-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 240ms ease;
  }

  .case-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.05), rgba(15, 23, 42, 0.88));
  }

  .case-card:hover img {
    transform: scale(1.04);
  }

  .case-card div {
    position: relative;
    z-index: 1;
    padding: 1.25rem;
  }

  .case-card h3 {
    color: #fff;
    margin: 0 0 0.4rem;
    font-size: 1.12rem;
  }

  .case-card p {
    color: #e2e8f0;
