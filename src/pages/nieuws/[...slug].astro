---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const allPosts = await getCollection("blog");
const related = allPosts
  .filter((p) => p.slug !== entry.slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);
---

<BaseLayout title={entry.data.title} description={entry.data.description} currentPath={`/nieuws/${entry.slug}/`}>
  <div class="breadcrumbs">
    <div class="container">
      <a href="/">Home</a> / <a href="/nieuws/">Blog</a> / <span>{entry.data.title}</span>
    </div>
  </div>

  {entry.data.image && (
    <div class="post-hero-img">
      <img src={entry.data.image} alt={entry.data.title} />
    </div>
  )}

  <article class="container post-article">
    <div class="post-meta">
      <time datetime={entry.data.pubDate.toISOString()}>
        {entry.data.pubDate.toLocaleDateString("nl-NL", { year: "numeric", month: "long", day: "numeric" })}
      </time>
      {entry.data.author && <span class="post-author">Door {entry.data.author}</span>}
    </div>
    <h1>{entry.data.title}</h1>
    <Content />
    <div class="post-nav">
      <a href="/nieuws/">&larr; Terug naar het overzicht</a>
    </div>
  </article>

  {related.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <h2>Gerelateerde berichten</h2>
        <div class="post-grid">
          {related.map(p => (
            <a href={`/nieuws/${p.slug}/`} class="post-card">
              {p.data.image && <img src={p.data.image} alt={p.data.title} width="400" height="250" loading="lazy" />}
              <div class="post-card-body">
                <h3>{p.data.title}</h3>
                <time>{p.data.pubDate.toLocaleDateString("nl-NL", { year: "numeric", month: "long", day: "numeric" })}</time>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .breadcrumbs { background: #f9fafb; padding: 0.75rem 0; font-size: 0.813rem; color: #6b7280; }
  .breadcrumbs a { color: #6b7280; text-decoration: none; }
  .breadcrumbs a:hover { color: #1a56db; }
  .breadcrumbs span { color: #1f2937; }
  .post-hero-img { background: #f3f4f6; }
  .post-hero-img img { width: 100%; max-height: 400px; object-fit: cover; display: block; border-radius: 0; }
  .post-article { max-width: 750px; padding: 3rem 1.5rem; }
  .post-article h1 { margin-top: 0; }
  .post-meta { display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .post-author { font-size: 0.875rem; color: #6b7280; }
  .post-nav { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e5e7eb; }
  .post-nav a { font-weight: 500; }
  .section { padding: 4rem 0; }
  .section-alt { background: #f9fafb; }
  .section h2 { margin-top: 0; margin-bottom: 2rem; }
  .post-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
  .post-card { display: block; border-radius: 0.75rem; overflow: hidden; border: 1px solid #e5e7eb; text-decoration: none; color: inherit; transition: box-shadow 0.2s, transform 0.2s; }
  .post-card:hover { box-shadow: 0 10px 40px rgba(0,0,0,0.1); transform: translateY(-3px); color: inherit; }
  .post-card img { width: 100%; height: 200px; object-fit: cover; border-radius: 0; }
  .post-card-body { padding: 1.25rem; }
  .post-card-body h3 { margin: 0 0 0.5rem; font-size: 1rem; line-height: 1.3; }
  .post-card-body time { font-size: 0.813rem; color: #9ca3af; margin: 0; }
</style>
