---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
  currentPath?: string;
}

const { title, description, canonical, noindex, ogImage, currentPath } = Astro.props;
const site = "https://clubdisplay.nl";
const defaultDesc =
  "ClubDisplay is een gespecialiseerd digital signage bureau. Wij leveren professionele schermoplossingen voor hospitality, horeca, retail, coffeeshops en kantoren.";
const pageTitle = `${title} | ClubDisplay`;
const pageDesc = description || defaultDesc;
const canonicalUrl = canonical || (currentPath ? `${site}${currentPath}` : site);
const pageUrl = canonicalUrl;
const imageUrl = ogImage || `${site}/images/og-default.jpg`;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex ? <meta name="robots" content="noindex, follow" /> : <meta name="robots" content="index, follow, max-image-preview:large" />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ClubDisplay" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content="nl_NL" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "ClubDisplay",
      "url": "https://clubdisplay.nl",
      "logo": "https://clubdisplay.nl/images/logo_club_Display.jpg",
      "description": "ClubDisplay is een gespecialiseerd digital signage bureau. Wij leveren en implementeren professionele schermoplossingen voor hospitality, horeca, retail, coffeeshops, kantoren en andere zakelijke omgevingen.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Meer en Duin #247",
        "addressLocality": "Lisse",
        "postalCode": "2163 HE",
        "addressCountry": "NL"
      },
      "telephone": "+31857602202",
      "email": "info@clubdisplay.nl",
      "vatID": "NL856050830B01",
      "sameAs": [],
      "knowsAbout": [
        "Digital Signage", "Hospitality TV", "IPTV", "LG Pro:Centric",
        "Digital Menu Boards", "Narrowcasting", "Digital Signage Hardware",
        "Coffeeshop Signage", "Wayfinding", "Room Signage", "Chromecast for Hotels"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Digital Signage Oplossingen",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Hospitality TV & IPTV" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Interactieve Televisie" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Digitale Menuborden" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Narrowcasting Software" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Digital Signage Hardware" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Coffeeshop Signage" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Wayfinding & Room Signage" } }
        ]
      }
    }
    </script>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --primary: #3f77b7;
        --primary-rgb: 63, 119, 183;
        --primary-dark: #245c94;
        --brand-accent: #5690d3;
        --brand-accent-rgb: 86, 144, 211;
        --primary-light: #dcecf8;
        --primary-50: #f3f8fd;
        --text: #0f172a;
        --text-secondary: #475569;
        --text-muted: #94a3b8;
        --bg: #ffffff;
        --bg-alt: #f8fafc;
        --bg-dark: #0f172a;
        --border: #e2e8f0;
        --border-light: #f1f5f9;
        --radius-sm: 8px;
        --radius: 12px;
        --radius-lg: 16px;
        --radius-xl: 28px;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
        --shadow: 0 4px 12px rgba(0,0,0,0.05);
        --shadow-md: 0 8px 28px rgba(0,0,0,0.06);
        --shadow-lg: 0 16px 48px rgba(0,0,0,0.08);
        --shadow-xl: 0 24px 64px rgba(0,0,0,0.10);
        --font: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        --font-display: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      }
      html { scroll-behavior: smooth; scroll-padding-top: 5rem; }
      body {
        font-family: var(--font);
        color: var(--text);
        line-height: 1.6;
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      :focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
        border-radius: 4px;
      }
      ::selection { background: var(--primary-light); color: var(--primary-dark); }

      .container {
        width: min(100% - 96px, 1180px);
        margin-inline: auto;
      }

      main { min-height: 65vh; }

      h1, h2, h3, h4 { font-family: var(--font-display); color: var(--text); }
      h1 { font-size: clamp(2rem, 3.5vw, 3.5rem); font-weight: 800; line-height: 1.08; letter-spacing: -0.03em; margin-bottom: 1.5rem; }
      h2 { font-size: clamp(1.625rem, 2.5vw, 2.5rem); font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 1.25rem; }
      h3 { font-size: clamp(1.125rem, 1.4vw, 1.375rem); font-weight: 600; line-height: 1.35; margin-bottom: 0.75rem; }
      h4 { font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem; }
      p { margin-bottom: 1.25rem; color: var(--text-secondary); font-size: 1rem; line-height: 1.7; }

      a { color: var(--primary); text-decoration: none; transition: color 0.15s; }
      a:hover { color: var(--primary-dark); }
      ul, ol { margin-bottom: 1.25rem; padding-left: 1.5rem; color: var(--text-secondary); }
      li { margin-bottom: 0.4rem; }
      img { max-width: 100%; height: auto; border-radius: var(--radius); display: block; }
      strong { color: var(--text); font-weight: 600; }
      blockquote {
        border-left: 3px solid var(--primary-light);
        padding: 1rem 1.5rem; margin: 1.5rem 0;
        background: var(--bg-alt);
        border-radius: 0 var(--radius) var(--radius) 0;
      }
      blockquote p { margin-bottom: 0; font-style: italic; }
      hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

      .page-content { padding: 4rem 0; max-width: 860px; margin: 0 auto; }
      .page-content h1 { margin-top: 0; }
      .page-content h2 { margin-top: 2.5rem; }
      time { font-size: 0.875rem; color: var(--text-muted); display: block; margin-bottom: 1.5rem; }
      .breadcrumbs {
        background: var(--bg-alt); padding: 0.75rem 0;
        font-size: 0.813rem; color: var(--text-muted);
      }
      .breadcrumbs a { color: var(--text-muted); }
      .breadcrumbs a:hover { color: var(--primary); }
      .breadcrumbs span { color: var(--text); }

      .btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: var(--primary); color: #fff; font-weight: 600;
        padding: 1rem 2.25rem; border-radius: 999px;
        font-size: 0.938rem; text-decoration: none; font-family: var(--font);
        border: none; cursor: pointer; line-height: 1;
        box-shadow: 0 4px 16px rgba(var(--primary-rgb),0.22);
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
      }
      .btn:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(var(--primary-rgb),0.32); color: #fff; }
      .btn:active { transform: translateY(0); }
      .btn-lg { padding: 1.125rem 2.75rem; font-size: 1.0625rem; }
      .btn-sm { padding: 0.5rem 1.25rem; font-size: 0.8125rem; box-shadow: none; }
      .btn-outline {
        background: #fff; border: 1.5px solid var(--primary);
        color: var(--primary) !important; box-shadow: 0 1px 2px rgba(0,0,0,0.04);
      }
      .btn-outline:hover { background: var(--primary); color: #fff !important; border-color: var(--primary); box-shadow: 0 8px 28px rgba(var(--primary-rgb),0.32); }
      .btn-white {
        background: #fff; color: var(--primary) !important; box-shadow: 0 4px 16px rgba(0,0,0,0.06);
      }
      .btn-white:hover { background: #fff; box-shadow: 0 12px 32px rgba(0,0,0,0.12); transform: translateY(-2px); }

      .text-center { text-align: center; }
      .text-primary { color: var(--primary); }
      .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }

      @media (max-width: 768px) {
        .container { width: min(100% - 32px, 1180px); }
        h1 { font-size: 1.875rem; }
        h2 { font-size: 1.5rem; }
        h3 { font-size: 1.125rem; }
        p { font-size: 0.938rem; }
        .page-content { padding: 2.5rem 0; }
        .btn { font-size: 0.875rem; padding: 0.75rem 1.5rem; }
        .btn-lg { padding: 0.875rem 2rem; font-size: 0.938rem; }
      }
    </style>
  </head>
  <body>
    <Navigation currentPath={currentPath || Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
