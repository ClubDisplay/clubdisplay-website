---

<section style="padding:104px 0;background:#fff;overflow:hidden;">
  <div style="width:min(calc(100% - 120px),1180px);margin:0 auto;">
    <div style="display:flex;justify-content:flex-end;gap:12px;margin-bottom:28px;">
      <button type="button" data-case-prev aria-label="Vorige cases" style="width:48px;height:48px;border-radius:999px;border:2px solid var(--primary);background:#fff;color:var(--primary);font-size:28px;line-height:1;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;">
        ‹
      </button>
      <button type="button" data-case-next aria-label="Volgende cases" style="width:48px;height:48px;border-radius:999px;border:2px solid var(--primary);background:#fff;color:var(--primary);font-size:28px;line-height:1;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;">
        ›
      </button>
    </div>

    <div style="display:grid;grid-template-columns:300px minmax(0,1fr);gap:72px;align-items:center;">
      <div>
        <h2 style="margin:0;color:#16113c;font-size:clamp(32px,3vw,46px);line-height:1.05;letter-spacing:-.035em;font-weight:800;">
          Ontdek onze projecten
        </h2>
        <p style="margin:20px 0 0;color:#2f2a55;font-size:16px;line-height:1.75;">
          Laat u inspireren door digital signage projecten voor hotels, horeca, retail en coffeeshops.
        </p>
        <a href="/cases/" style="display:inline-flex;align-items:center;justify-content:center;margin-top:28px;min-height:48px;padding:0 24px;border-radius:999px;background:var(--primary);color:#fff;font-size:15px;font-weight:800;text-decoration:none;">
          Bekijk alle projecten
        </a>
      </div>

      <div data-case-rail style="display:grid;grid-auto-flow:column;grid-auto-columns:minmax(260px,320px);gap:28px;overflow-x:auto;padding:8px 34px 14px 0;scroll-behavior:smooth;scrollbar-width:none;background:transparent;">
        {cases.map((item) => (
          <a href={item.href} class="case-card-motion" style="position:relative;display:block;min-height:380px;overflow:hidden;border-radius:10px;background:transparent;box-shadow:0 18px 40px rgba(15,23,42,.16);color:#fff;text-decoration:none;transition:transform .28s ease, box-shadow .28s ease;">
            <img src={item.image} alt={item.title} loading="lazy" style="display:block;width:100%;height:380px;object-fit:cover;border-radius:0;transition:transform .38s ease;" />
            <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(15,23,42,0) 35%,rgba(15,23,42,.88) 100%);"></div>
            <div style="position:absolute;left:18px;right:18px;bottom:18px;">
              <div style="margin-bottom:7px;color:rgba(255,255,255,.78);font-size:12px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;">
                {item.category}
              </div>
              <h3 style="margin:0;color:#fff;font-size:23px;line-height:1.12;letter-spacing:-.025em;font-weight:800;">
                {item.title}
              </h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const rail = document.querySelector('[data-case-rail]');
  const prev = document.querySelector('[data-case-prev]');
  const next = document.querySelector('[data-case-next]');

  prev?.addEventListener('click', () => {
    rail?.scrollBy({ left: -360, behavior: 'smooth' });
  });

  next?.addEventListener('click', () => {
    rail?.scrollBy({ left: 360, behavior: 'smooth' });
  });
</script>

<style>
  .case-card-motion:hover {
    transform: translateY(-8px);
    box-shadow: 0 26px 56px rgba(15,23,42,.22) !important;
  }

  .case-card-motion:hover img {
    transform: scale(1.06);
  }

  [data-case-rail]::-webkit-scrollbar {
    display: none;
  }
</style>
