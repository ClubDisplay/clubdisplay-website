---
interface Props {
  currentPath?: string;
}
const { currentPath = "/" } = Astro.props;

interface MenuItem {
  label: string;
  href?: string;
  children?: Array<{ label: string; href: string }>;
}

const menu: MenuItem[] = [
  { label: "Home", href: "/" },
  {
    label: "Oplossingen",
    children: [
      { label: "Hospitality TV & IPTV", href: "/zakelijke-iptv-voor-hotels-en-bedrijven/" },
      { label: "Interactieve Televisie", href: "/interactieve-televisie/" },
      { label: "Digitale menuborden", href: "/digitale-menuborden/" },
      { label: "Narrowcasting software", href: "/narrowcasting/" },
      { label: "Digital signage hardware", href: "/displays/" },
      { label: "Wayfinding & room signage", href: "/wayfinding-en-room-signage/" },
      { label: "Coffeeshop signage", href: "/coffeeshop-signage/" },
      { label: "Etalageschermen", href: "/etalageschermen/" },
    ],
  },
  {
    label: "Over ons",
    children: [
      { label: "Over ClubDisplay", href: "/over-ons/" },
      { label: "Cases", href: "/cases/" },
      { label: "Support", href: "/service-support/" },
    ],
  },
];

function isActive(item: MenuItem): boolean {
  if (item.href && currentPath === item.href) return true;
  if (item.children) return item.children.some((c) => currentPath === c.href);
  return false;
}
---

<nav class="nav" aria-label="Hoofdnavigatie">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="ClubDisplay home">
      <img src="/images/logo_club_Display.jpg" alt="ClubDisplay" width="180" height="52" />
    </a>
    <button class="nav-toggle" aria-label="Menu openen" aria-expanded="false" data-toggle>
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-menu" data-menu role="list">
      {menu.map((item) => (
        <li class:list={{ "nav-item": true, "has-sub": item.children, active: isActive(item) }}>
          {item.href ? (
            <a href={item.href} class="nav-link">{item.label}</a>
          ) : (
            <span class="nav-link nav-trigger" tabindex="0" role="button" aria-expanded="false">{item.label}</span>
          )}
          {item.children && (
            <div class="nav-sub">
              <div class="nav-sub-inner">
                {item.children.map((child) => (
                  <a href={child.href} class="nav-sub-link">{child.label}</a>
                ))}
              </div>
            </div>
          )}
        </li>
      ))}
      <li class="nav-item nav-support">
        <a href="/contact/#contactformulier" class="nav-support-link">Contact opnemen</a>
      </li>
    </ul>
    <div class="mobile-menu" data-mobile-menu>
      {menu.map((item) => (
        item.href ? (
          <a href={item.href} class="mobile-link">{item.label}</a>
        ) : (
          <div class="mobile-group">
            <div class="mobile-heading">{item.label}</div>
            <div class="mobile-links">
              {item.children?.map((child) => (
                <a href={child.href} class="mobile-sub-link">{child.label}</a>
              ))}
            </div>
          </div>
        )
      ))}
      <a href="/contact/#contactformulier" class="mobile-cta">Contact opnemen</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.querySelector('[data-toggle]');
  const menu = document.querySelector('[data-menu]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  const nav = document.querySelector('.nav');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('open');
    toggle?.setAttribute('aria-expanded', String(isOpen));
    toggle?.classList.toggle('open');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  document.querySelectorAll('.nav-trigger').forEach((trigger) => {
    trigger.addEventListener('click', (e) => {
      if (window.innerWidth <= 900) {
        e.preventDefault();
        const parent = trigger.closest('.nav-item');
        const sub = parent?.querySelector('.nav-sub');
        const expanded = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', String(!expanded));
        parent?.classList.toggle('open', !expanded);
        sub?.classList.toggle('open');
      }
    });
  });

  document.querySelectorAll('.nav-menu a').forEach((link) => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 900) {
        menu?.classList.remove('open');
        mobileMenu?.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
        toggle?.classList.remove('open');
        document.body.style.overflow = '';
      }
    });
  });

  document.querySelectorAll('.mobile-menu a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  document.addEventListener('click', (e) => {
    if (!nav?.contains(e.target as Node)) {
      document.querySelectorAll('.nav-item.open').forEach((el) => el.classList.remove('open'));
    }
  });
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border-light);
    height: 4.75rem;
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .nav-logo { flex-shrink: 0; display: flex; align-items: center; }
  .nav-logo img { display: block; height: 2.55rem; width: auto; border-radius: 0; }

  .nav-menu {
    display: flex;
    gap: 0.125rem;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
    height: 100%;
  }
  .nav-item {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
  }
  .nav-link {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.875rem;
    text-decoration: none;
    padding: 0 0.875rem;
    height: 100%;
    display: flex;
    align-items: center;
    cursor: pointer;
    transition: color 0.15s;
    white-space: nowrap;
    position: relative;
  }
  .nav-link::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.875rem;
    right: 0.875rem;
    height: 2px;
    background: var(--primary);
    transform: scaleX(0);
    transition: transform 0.2s;
  }
  .nav-item:hover .nav-link,
  .nav-item.active .nav-link { color: var(--primary); }
  .nav-item:hover .nav-link::before,
  .nav-item.active .nav-link::before { transform: scaleX(1); }
  .nav-trigger { gap: 0.375rem; background: none; border: none; font-family: var(--font); font-size: 0.875rem; }
  .nav-trigger::after {
    content: '';
    display: inline-block;
    width: 0.375rem;
    height: 0.375rem;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg);
    margin-top: -2px;
    transition: transform 0.2s;
  }
  .nav-item:hover .nav-trigger::after { transform: rotate(225deg); margin-top: 2px; }

  .nav-sub {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 0.5rem;
  }
  .has-sub:hover .nav-sub { display: block; }
  .nav-sub-inner {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    min-width: 230px;
    padding: 0.5rem;
  }
  .nav-sub-link {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    border-radius: var(--radius-sm);
    transition: background 0.12s, color 0.12s;
  }
  .nav-sub-link:hover { background: var(--primary-50); color: var(--primary); }

  .nav-item.nav-cta { padding-left: 0.5rem; }
  .nav-item.nav-cta .btn { font-size: 0.8125rem; padding: 0.5rem 1.125rem; }
  .nav-support { padding-left: 0.5rem; }
  .nav-support-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0 1rem;
    border-radius: 999px;
    background: var(--primary);
    color: #fff !important;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
  }
  .nav-support-link:hover { background: var(--primary-dark); color: #fff !important; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }
  .nav-toggle.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  .mobile-menu {
    display: none;
  }

  @media (max-width: 900px) {
    .nav-toggle { display: flex; }
    .nav-menu {
      display: none;
    }
    .nav-menu.open { display: none; }

    .mobile-menu {
      display: none;
      position: fixed;
      top: 4.75rem;
      left: 0;
      right: 0;
      bottom: 0;
      background: #fff;
      padding: 1.1rem 1.5rem 2rem;
      width: 100%;
      overflow-y: auto;
      border-top: 1px solid var(--border-light);
      box-shadow: 0 18px 45px rgba(15,23,42,0.12);
    }
    .mobile-menu.open {
      display: block;
    }
    .mobile-link,
    .mobile-heading {
      display: flex;
      align-items: center;
      min-height: 2.9rem;
      color: var(--text);
      font-size: 1rem;
      font-weight: 800;
      text-decoration: none;
      border-bottom: 1px solid var(--border-light);
    }
    .mobile-heading {
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-size: 0.82rem;
      margin-top: 0.5rem;
    }
    .mobile-links {
      display: grid;
      gap: 0.2rem;
      padding: 0.6rem 0 0.95rem 0.85rem;
      border-bottom: 1px solid var(--border-light);
    }
    .mobile-sub-link {
      display: block;
      padding: 0.55rem 0;
      color: var(--text-secondary);
      font-size: 0.98rem;
      font-weight: 650;
      text-decoration: none;
    }
    .mobile-sub-link:hover,
    .mobile-link:hover {
      color: var(--primary);
    }
    .mobile-cta {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 3rem;
      margin-top: 1rem;
      border-radius: 999px;
      background: var(--primary);
      color: #fff;
      font-size: 1rem;
      font-weight: 800;
      text-decoration: none;
    }

    .nav-item.nav-cta {
      padding: 1rem 0 0;
    }
    .nav-item.nav-cta .btn {
      width: 100%;
      justify-content: center;
      padding: 0.75rem;
      font-size: 0.938rem;
    }
  }
</style>
